# Neon Postgres connection string (from your Neon Console)
DATABASE_URL="postgresql://user:password@host/neondb?sslmode=require&channel_binding=require"

# JWT signing secret for the legacy auth layer (32+ chars)
JWT_SECRET="change-me-to-a-32-char-secret"

# Email allowlist — only this email can register
# Defaults to "royokola3@gmail.com" if unset
ALLOWED_REGISTRATION_EMAIL="royokola3@gmail.com"

# ── Neon Auth (Goal B migration target) ─────────────────────────
# Enable Neon Auth in the Neon Console (Project → Branch → Auth),
# then copy the Auth URL and generate a cookie secret:
#   openssl rand -base64 32
# Until these are set, the legacy JWT auth remains active.
NEON_AUTH_BASE_URL=
NEON_AUTH_COOKIE_SECRET=

# App URL used for auth redirects
NEXT_PUBLIC_APP_URL="http://localhost:3000"
